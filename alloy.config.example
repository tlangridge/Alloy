# alloy configuration  (copy to ~/.config/alloy/config and edit)
#
# This file is parsed as simple KEY=value lines. It is NEVER executed as a
# shell script, so it is safe even if a copy ends up in a project directory.
# Lines starting with '#' and blank lines are ignored. Environment variables
# of the same name override values here.

# Which adapters form the panel (comma-separated, in order).
# Shipped + verified: codex, gemini. Experimental/off by default: antigravity.
ALLOY_PANELISTS=codex,gemini

# Per-panelist timeout in seconds. A hung CLI is killed (process group) at this.
ALLOY_TIMEOUT=240

# Cap on each panelist's captured output (characters). Protects the host's
# context window from a runaway panelist. Truncation is recorded in the manifest.
ALLOY_MAX_CHARS=200000

# Cap on total prompt size in bytes (the prompt plus any --attach files).
# Guards against a huge prompt exhausting memory before output caps apply.
ALLOY_MAX_PROMPT_BYTES=4000000

# Web research: panelists may search the web (codex tools.web_search; gemini's
# google_web_search in plan mode). On by default; set to 0 to disable (codex).
ALLOY_WEB=1

# Optional: comma-separated files to fold into every prompt as read-only
# reference context (also available per-run as `--attach`). Unset by default.
# ALLOY_ATTACH=src/foo.ts,src/bar.ts

# Optional model overrides (leave unset to use each CLI's default model).
# ALLOY_CODEX_MODEL=gpt-5.2-codex
# ALLOY_GEMINI_MODEL=gemini-2.5-pro

# Who judges the panel. Default is the host (Claude). Judge rotation to a CLI is
# on the roadmap; today this is informational.
# ALLOY_JUDGE=claude

# Where run output (prompts, per-panelist answers, manifest.json) is written.
# Default: $XDG_STATE_HOME/alloy/runs (i.e. ~/.local/state/alloy/runs) -- kept
# OUTSIDE your repo so prompts/diffs and CLI output are never committed.
# ALLOY_RUN_ROOT=~/.cache/alloy/runs

# DANGER: allow adapters that have no real read-only mode (e.g. cursor-agent).
# Off by default. Only enable if you understand that such a panelist can write
# files and run shell, contained only by alloy's throwaway working directory.
# ALLOY_ALLOW_UNSANDBOXED=0

# Disable the throttled, git-based update check (the one optional network call
# Alloy makes; it sends no data of its own).
# ALLOY_NO_UPDATE_CHECK=0
